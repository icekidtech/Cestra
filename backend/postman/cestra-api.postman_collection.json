          "name": "POST Batch Payout — valid CSV",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 201', () => pm.response.to.have.status(201));", "pm.test('batch_id and status present', () => { const b = pm.response.json(); pm.expect(b).to.have.property('batch_id'); pm.expect(b.status).to.equal('PROCESSING'); });"] }
