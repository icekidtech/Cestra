{
  "info": {
    "_postman_id": "cestra-api-collection",
    "name": "Cestra API",
    "description": "Complete API collection for the Cestra stablecoin payment platform backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "{{base_url}}" },
    { "key": "jwt_token", "value": "{{jwt_token}}" },
    { "key": "api_key", "value": "{{api_key}}" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('access_token present', () => {",
                  "  const b = pm.response.json();",
                  "  pm.expect(b).to.have.property('access_token');",
                  "  pm.expect(b).to.have.property('wallet_address');",
                  "  pm.expect(b).to.have.property('user_id');",
                  "  pm.environment.set('jwt_token', b.access_token);",
                  "  pm.environment.set('test_user_id', b.user_id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"zklogin_token\": \"eyJ3YWxsZXRfYWRkcmVzcyI6IjB4YWJjMTIzIiwicHJvdmlkZXIiOiJnb29nbGUifQ==\",\n  \"provider\": \"google\"\n}"
            }
          }
        },
        {
          "name": "POST Login — invalid token (expect 401)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 401', () => pm.response.to.have.status(401));"] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"zklogin_token\": \"invalid\",\n  \"provider\": \"google\"\n}" }
          }
        },
        {
          "name": "POST KYC Initiate",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));", "pm.test('session_url present', () => pm.expect(pm.response.json()).to.have.property('session_url'));"] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/auth/kyc",
            "body": { "mode": "raw", "raw": "{\n  \"tier\": 1\n}" }
          }
        },
        {
          "name": "POST KYC Webhook (Persona callback)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/kyc/webhook",
            "body": { "mode": "raw", "raw": "{\n  \"data\": {\n    \"attributes\": {\n      \"status\": \"approved\",\n      \"reference_id\": \"{{test_user_id}}\"\n    }\n  }\n}" }
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "GET Balance",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));", "pm.test('balance fields present', () => { const b = pm.response.json(); pm.expect(b).to.have.property('balance_usdsui'); pm.expect(b).to.have.property('yield_balance'); pm.expect(b).to.have.property('apy'); });"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/wallet/balance"
          }
        },
        {
          "name": "POST Fund ACH",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 201', () => pm.response.to.have.status(201));", "pm.test('status is PENDING', () => pm.expect(pm.response.json().status).to.equal('PENDING'));"] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/wallet/fund/ach",
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 100,\n  \"plaid_token\": \"access-sandbox-abc123\"\n}" }
          }
        },
        {
          "name": "POST Fund ACH — amount < $1 (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 400', () => pm.response.to.have.status(400));"] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/wallet/fund/ach",
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 0.50,\n  \"plaid_token\": \"access-sandbox-abc123\"\n}" }
          }
        },
        {
          "name": "POST Fund Cross-Chain",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 201', () => pm.response.to.have.status(201));", "pm.test('address present', () => pm.expect(pm.response.json()).to.have.property('address'));"] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/wallet/fund/crosschain",
            "body": { "mode": "raw", "raw": "{\n  \"source_chain\": \"ethereum\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Send",
      "item": [
        {
          "name": "POST Send",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 201', () => pm.response.to.have.status(201));", "pm.test('tx_id and fee present', () => { const b = pm.response.json(); pm.expect(b).to.have.property('id'); pm.expect(b.status).to.equal('PENDING'); const req = JSON.parse(pm.request.body.raw); pm.expect(parseFloat(b.fee)).to.be.closeTo(req.amount * 0.008, 0.000001); pm.environment.set('test_tx_id', b.id); });"] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt_token}}" }, { "key": "Idempotency-Key", "value": "test-send-001" }],
            "url": "{{base_url}}/send",
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 50,\n  \"recipient_id\": \"{{test_recipient_id}}\",\n  \"corridor\": \"USD-NGN\"\n}" }
          }
        },
        {
          "name": "POST Send — insufficient balance (expect 422)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 422', () => pm.response.to.have.status(422));"] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/send",
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 9999999,\n  \"recipient_id\": \"{{test_recipient_id}}\",\n  \"corridor\": \"USD-NGN\"\n}" }
          }
        },
        {
          "name": "GET Send Status",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));", "pm.test('tx_id and status present', () => { const b = pm.response.json(); pm.expect(b).to.have.property('tx_id'); pm.expect(b).to.have.property('status'); });"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/send/{{test_tx_id}}/status"
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "GET Transaction History",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));", "pm.test('pagination metadata present', () => { const b = pm.response.json(); pm.expect(b).to.have.property('items'); pm.expect(b).to.have.property('total'); pm.expect(b).to.have.property('page'); pm.expect(b).to.have.property('limit'); pm.expect(b).to.have.property('total_pages'); pm.expect(b.total_pages).to.equal(Math.ceil(b.total / b.limit)); });"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": { "raw": "{{base_url}}/transactions?page=1&limit=20", "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }] }
          }
        },
        {
          "name": "GET Transaction History — filter by type=sent",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));", "pm.test('all items are type sent', () => { pm.response.json().items.forEach(t => pm.expect(t.type).to.equal('sent')); });"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": { "raw": "{{base_url}}/transactions?type=sent", "query": [{ "key": "type", "value": "sent" }] }
          }
        }
      ]
    },
