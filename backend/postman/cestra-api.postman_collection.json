            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Amara Okafor\",\n  \"country\": \"NG\",\n  \"mobile_money_type\": \"MTN_MOMO\",\n  \"account_number\": \"08012345678\"\n}" }
          }
        },
