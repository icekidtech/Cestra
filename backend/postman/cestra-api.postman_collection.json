          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/recipients",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Amara Okafor\",\n  \"country\": \"NG\",\n  \"mobile_money_type\": \"MTN_MOMO\",\n  \"account_number\": \"08012345678\"\n}" }
          }
        },
        {
          "name": "GET List Recipients",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));", "pm.test('returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/recipients"
          }
        }
      ]
