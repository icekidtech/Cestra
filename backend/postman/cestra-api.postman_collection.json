          "request": {
            "method": "POST",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": "{{base_url}}/business/batch-payout",
            "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "/path/to/invalid-batch.csv" }] }
