# PostgreSQL connection
DB_HOST=localhost          # Database host (e.g. localhost or a Docker service name)
DB_PORT=5432               # Database port (default PostgreSQL port)
DB_NAME=cestra_dev         # Database name to connect to
DB_USER=cestra             # PostgreSQL username
DB_PASSWORD=changeme       # PostgreSQL password — replace before use

# Application
JWT_SECRET=replace_with_a_long_random_secret  # Secret used to sign JWT tokens
APP_PORT=3000              # Port the NestJS HTTP server listens on
