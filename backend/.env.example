# PostgreSQL connection
DB_HOST=localhost          # Database host (e.g. localhost or a Docker service name)
DB_PORT=5432               # Database port (default PostgreSQL port)
DB_NAME=cestra_dev         # Database name to connect to
DB_USER=cestra             # PostgreSQL username
DB_PASSWORD=changeme       # PostgreSQL password — replace before use

# Application
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars  # Secret used to sign JWT tokens (minimum 32 characters recommended)
APP_PORT=3000              # Port the NestJS HTTP server listens on (default: 3000)
APP_BASE_URL=http://localhost:3000  # Base URL of this API — used to generate hosted payment URLs (e.g. invoice payment links)

# Redis (run via Docker — see docker-compose.yml)
REDIS_HOST=localhost       # Redis host (default: localhost when using Docker)
REDIS_PORT=6379            # Redis port (default: 6379)

# Plaid — ACH bank pull integration
PLAID_CLIENT_ID=           # Plaid API client ID for ACH bank pulls
PLAID_SECRET=              # Plaid API secret key

# Persona — KYC verification
PERSONA_API_KEY=           # Persona API key for KYC identity verification sessions

# CORS
CORS_ORIGINS=http://localhost:3001,https://app.cestra.io  # Comma-separated list of allowed CORS origins

# Environment
NODE_ENV=development       # Application environment: development | test | production (default: development)
